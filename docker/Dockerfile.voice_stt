FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

WORKDIR /app

RUN pip install --no-cache-dir \
    discord.py==2.7.0 \
    PyNaCl==1.5.0 \
    faster-whisper \
    duckduckgo-search==7.5.5

COPY src /app/src

CMD ["python", "-m", "voice_stt_agent.main"]
